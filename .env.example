# Environment
NODE_ENV=development
PORT=3000
HOST=localhost

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE_MB=50
MAX_BATCH_PARCELS=10000

# Feature Flags
ENABLE_FILE_UPLOAD=true
ENABLE_BATCH_ROUTE=true
ENABLE_METRICS=true

# Database (Future)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parcel_routing
DB_USER=postgres
DB_PASSWORD=

# Security Keys (Future)
API_KEY=
JWT_SECRET=
